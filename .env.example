# ── OCULTAR Configuration ──────────────────────────────────────────

# REQUIRED: 32-byte master key for AES-256 encryption.

# REQUIRED: Per-deployment salt.

# OPTIONAL: Proxy configuration
OCU_PROXY_TARGET=https://api.openai.com
OCU_PROXY_PORT=8081

# ENTERPRISE: License key and SLM host
OCU_LICENSE_KEY=HSKTMfEnIYdTRmyOohu8DcQh8PRGUIhvTlaOFV+dc+LLm04kAok5RmgpzGldoqwTuiwdy3wi4JlftcOLn+4ICQ==.eyJDdXN0b21lck5hbWUiOiJEZXZlbG9wbWVudCIsIlRpZXIiOiJlbnRlcnByaXNlIiwiRXhwaXJ5RGF0ZSI6MTgwNTY2NzkyNSwiQ2FwYWJpbGl0aWVzIjozfQ==

# ENTERPRISE: Immutable audit log (SHA-256 hash chain + Ed25519 signatures)
# Generate key seed: openssl rand -hex 32
# The same seed must be retained to verify historical signatures after restarts.
# If unset, audit logging is disabled (NoopAuditLogger).
OCU_AUDIT_PRIVATE_KEY=
# Path for the audit log file. Defaults to audit.log in the same dir as OCU_VAULT_PATH.
OCU_AUDIT_LOG_PATH=/data/audit.log

# Provider API Keys
OPENAI_API_KEY=sk-mock-pilot-key-12345
GEMINI_API_KEY=your-gemini-key-goes-here

SLM_HOST=http://localhost:8080

# SOMBRA: AI Provider Keys
OCU_MASTER_KEY=replace-with-a-secure-32-byte-key
OCU_SALT=ocultar-v112-kdf-salt-fix# Registry Sync (Enterprise)
CRM_ENDPOINT=
CRM_API_KEY=
SYNC_INTERVAL=1h

# Native AI Inference (Enterprise) — Tier 2 SLM engine
# SLM_ENGINE=llama          # default; requires SLM_MODEL_PATH and CGO
# SLM_ENGINE=privacy-filter # Apache 2.0 token classifier; requires PYTHON_SIDECAR_URL
SLM_ENGINE=llama
SLM_MODEL_PATH=models/qwen-1.5b-q4_k_m.gguf
# PYTHON_SIDECAR_URL=http://localhost:8086
# PRIVACY_FILTER_MODEL_PATH=openai/privacy-filter
GEMINI_API_KEY=
CLAUDE_API_KEY=
