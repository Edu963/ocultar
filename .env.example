# ─────────────────────────────────────────────────────────────────────────────
# OCULTAR — Environment Configuration
#
# Usage:
#   cp .env.example .env          # one-time setup
#   docker compose up --build     # demo stack (Tier 1, zero config)
#
# These defaults are SAFE FOR DEMO/DEV ONLY. Replace all values before
# connecting to real data or a production upstream.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (Required) ──────────────────────────────────────────────────────────

# Key material for HKDF-SHA256 derivation. Any string works; entropy matters in prod.
# Production: openssl rand -hex 32
OCU_MASTER_KEY=ocultar-demo-master-key-change-in-prod

# Per-deployment salt. Must remain stable across restarts — changing it invalidates
# all stored tokens (re-tokenization required).
OCU_SALT=ocultar-demo-salt-change-in-prod

# ── Proxy ─────────────────────────────────────────────────────────────────────

# Upstream API the proxy forwards to.
# docker-compose.yml overrides this automatically for the local demo.
OCU_PROXY_TARGET=https://api.openai.com
OCU_PROXY_PORT=8081

# DuckDB vault path. Mounted as a named Docker volume in compose.
OCU_VAULT_PATH=/data/vault.db

# ── Demo / Development ───────────────────────────────────────────────────────

# Set to 1 to run Tiers 0–1.5 only (no SLM sidecar required).
# Remove or set to 0 for full enterprise mode (requires --profile ai).
OCU_PILOT_MODE=1

# ── Provider API Keys ─────────────────────────────────────────────────────────

# Real keys required for live upstream routing.
# Mock values below work with the echo-upstream demo target.
OPENAI_API_KEY=sk-mock-demo-key-replace-in-prod
GEMINI_API_KEY=
CLAUDE_API_KEY=

# ── Enterprise: License ───────────────────────────────────────────────────────

# Base64-encoded Ed25519 license. Leave blank for community tier.
OCU_LICENSE_KEY=

# ── Enterprise: Immutable Audit Log ──────────────────────────────────────────

# Ed25519 seed for hash-chained audit signatures.
# Generate: openssl rand -hex 32
# Must be retained across restarts to verify historical signatures.
# If unset, audit logging is disabled (NoopAuditLogger).
OCU_AUDIT_PRIVATE_KEY=
OCU_AUDIT_LOG_PATH=/data/audit.log

# ── Enterprise: Identity Sync (CRM / LDAP) ───────────────────────────────────

CRM_ENDPOINT=
CRM_API_KEY=
SYNC_INTERVAL=1h

# ── Enterprise: Tier 2 AI NER ────────────────────────────────────────────────

# Active when OCU_PILOT_MODE=0 and --profile ai is passed to docker compose.
#
# Options:
#   privacy-filter  — Apache 2.0 token classifier (recommended)
#   llama-cpp       — Qwen/llama.cpp generative NER (requires SLM_MODEL_PATH + CGO)
TIER2_ENGINE=privacy-filter
PYTHON_SIDECAR_URL=http://localhost:8086
PRIVACY_FILTER_MODEL_PATH=openai/privacy-filter

# llama-cpp backend only:
SLM_SIDECAR_URL=http://localhost:8085
SLM_MODEL_PATH=models/qwen-1.5b-q4_k_m.gguf
