# ── OCULTAR Configuration Template ──────────────────────────────────────────
# Copy to .env and fill in your values.

# REQUIRED: 32-byte master key for AES-256 encryption.
# Generate with: openssl rand -hex 32
OCU_MASTER_KEY=

# REQUIRED: Per-deployment salt.
# Generate with: openssl rand -hex 16
OCU_SALT=

# OPTIONAL: Proxy configuration
OCU_PROXY_TARGET=https://api.openai.com
OCU_PROXY_PORT=8080

# ENTERPRISE: License key and SLM host
OCU_LICENSE_KEY=
SLM_HOST=http://localhost:8080

# SOMBRA: AI Provider Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=
