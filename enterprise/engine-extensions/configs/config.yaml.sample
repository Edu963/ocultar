# OCULTAR Horizon Enterprise - Custom Rules Configuration
# This file is actively evaluated ONLY if an enterprise license is loaded.

presidio_confidence: 0.75

# --- Redaction Rules ---
regexes:
  - type: PATIENT_ID
    pattern: "(?i)PTN-\\d{6}"
  - type: TRANSACTION_CODE
    pattern: "TXN-[A-Z0-9]{8}"
  - type: EU_ADDRESS
    pattern: "(?i)(?:rue|avenue|boulevard|place|route|square|allee)\\s+[^,]+,\\s*[^,]+\\s+\\d{5}"

dictionaries:
  - type: INTERNAL_PROJECT
    terms:
      - "Project Apollo"
      - "Operation Starlight"
  - type: PERSON_VIP
    terms:
      - "Carlos Andrés Segura Gómez"
      - "Carlos Andrés Segura"
      - "Julie Dubief"

